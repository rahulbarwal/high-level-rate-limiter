{
  "name": "high-level",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "tsc",
    "docker:up": "docker compose up -d",
    "docker:up:build": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:down:volumes": "docker compose down -v",
    "docker:logs": "docker compose logs -f app",
    "docker:loadtest": "docker compose --profile loadtest run --rm loadtest npx ts-node scripts/loadtest.ts",
    "docker:loadtest:baseline": "docker compose --profile loadtest run --rm loadtest npx ts-node scripts/loadtest.ts baseline",
    "docker:loadtest:global": "docker compose --profile loadtest run --rm loadtest npx ts-node scripts/loadtest.ts global",
    "docker:loadtest:allow-reject": "docker compose --profile loadtest run --rm loadtest npx ts-node scripts/loadtest.ts allow-reject",
    "docker:test": "docker compose --profile test run --rm test",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1",
    "ioredis": "^5.10.0",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/autocannon": "^7.12.7",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "autocannon": "^8.0.0",
    "eslint": "^10.0.3",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
